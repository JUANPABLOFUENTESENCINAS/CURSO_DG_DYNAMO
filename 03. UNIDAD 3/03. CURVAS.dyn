    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "19e8c6d324894630b383173aaf5ea922",
      "NodeType": "CodeBlockNode",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "9d91db2d61b74066a5119e5c4470beac",
          "Name": "periodos",
          "Description": "periodos = 10",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "42e9dbc6adc14260b2af1ecc12f4078f",
          "Name": "resolucion",
          "Description": "resolucion = 100",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "0fa82191be374238a83153143b2472af",
          "Name": "x",
          "Description": "x = (0..(periodos * 2) * (DSCore.Math.PI)..#resolucion)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "1eff4804e008435c9f484f12130e6bd1",
          "Name": "y",
          "Description": "y = DSCore.Math.Sin((x / (DSCore.Math.PI)) * 180)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "// Generar puntos de una curva de seno con un Code Block:\nperiodos = 10;\n// número de ondas completas;\nresolucion = 100;\n// cantidad de puntos (más = curva más suave);\n//procedimiento\nx = 0..(periodos*2*Math.PI)..#resolucion;\n// dominio en radianes, para el eje X;\ny = Math.Sin(x / Math.PI * 180);\n// se convierte a grados solo para el cálculo;"
    },
